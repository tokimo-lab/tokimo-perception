# API authentication key (must match tokimo server's photo AI settings)
API_AUTH_KEY=mt_photos_ai_extra

# HTTP server port
HTTP_PORT=8060

# Model storage directory
MODELS_DIR=./models

# Feature toggles
ENABLE_OCR=on
ENABLE_CLIP=on
ENABLE_FACE=on

# Face detection backend
DETECTOR_BACKEND=scrfd

# Face recognition model
RECOGNITION_MODEL=arcface_w600k

# Logging
RUST_LOG=tokimo_ai=info
